# 本地开发可不配置；生产环境按需填写
# 复制为 .env 后修改: cp .env.example .env

PORT=3000
NODE_ENV=development

# 数据库（drizzle migrate 需要；不配也可启动，仅部分功能不可用）
# DATABASE_URL=mysql://user:pass@localhost:3306/dbname

# JWT 会话（不配则登录态可能异常）
# JWT_SECRET=your-secret

# OAuth 登录（不配会打日志，不影响本地跑）
# OAUTH_SERVER_URL=https://...
# OWNER_OPEN_ID=...

# 邮件（不配则联系表单不发邮件，接口仍返回成功）
# RESEND_API_KEY=re_...

# 前端/Forge 等（按需）
# VITE_APP_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
